# Copy this file to .env and adjust as needed for local development.
# docker-compose.yml already sets these for containerized runs; this file is
# for running the Python modules directly on your host machine.

PG_HOST=localhost
PG_PORT=5432
PG_DB=siem
PG_USER=siem_user
PG_PASSWORD=siem_password

# Detection rule tuning (all optional -- sane defaults are baked in)
BRUTE_FORCE_ATTEMPT_THRESHOLD=5
BRUTE_FORCE_WINDOW_MINUTES=5
IMPOSSIBLE_TRAVEL_MAX_KMH=900
UNUSUAL_HOUR_START=6
UNUSUAL_HOUR_END=22
MULTI_FAIL_THRESHOLD=10
MULTI_FAIL_WINDOW_MINUTES=60
ISOLATION_FOREST_CONTAMINATION=0.05

# Splunk HTTP Event Collector (only needed for scripts/send_to_splunk.py)
SPLUNK_HEC_URL=https://localhost:8088/services/collector
SPLUNK_HEC_TOKEN=
SPLUNK_VERIFY_SSL=false
SPLUNK_INDEX=siem
